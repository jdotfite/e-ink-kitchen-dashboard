# Copy to .env on the Raspberry Pi and fill in real values. Do not commit .env.
OPENWEATHER_API_KEY=
OPENWEATHER_LATITUDE=
OPENWEATHER_LONGITUDE=
DASHBOARD_LOCATION=Home
OPENWEATHER_UNITS=imperial
# 0=Monday, 6=Sunday. Example: Wednesday and Sunday -> 2,6
TRASH_DAYS=
CSV_ENABLED=true
REQUEST_CONNECT_TIMEOUT=5
REQUEST_READ_TIMEOUT=20
# Optional endpoint returning calendar/grocery/facts JSON (see README).
DASHBOARD_API_URL=
# Auth token sent as x-eink-token header to DASHBOARD_API_URL.
EINK_API_TOKEN=
